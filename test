local _salt = 78421

local function _hash(s)
    local h = _salt
    for i = 1, #s do
        local b = string.byte(s, i)
        h = bit32.bxor(h, b * (i + 11))
        h = (h * 16777619) % 2147483647
    end
    return h
end

